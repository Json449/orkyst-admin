      "success": true,
      "range": { "start": "2026-04-08", "end": "2026-05-08", "label": "Last 30 days" },
      "ctaPerformance": {
        "totalLinkClicks": { "value": 9900,  "deltaPct": 12.5, "deltaLabel": "+12.5% vs last month" },
        "siteVisits":      { "value": 6240,  "deltaPct":  8.3, "deltaLabel": "+8.3% vs last month"  },
        "newAudience":     { "value": 1847,  "deltaPct": 15.2, "deltaLabel": "+15.2% vs last month" },
        "avgCtr":          { "value": 0.039, "deltaPct":  0.4, "deltaLabel": "+0.4% vs last month"  }
      },
      "clicksByContentType": [
        { "type": "blog",           "label": "Blog Posts",     "clicks": 3120 },
        { "type": "case_study",     "label": "Case Studies",   "clicks": 1980 },
        { "type": "social_link",    "label": "Social Links",   "clicks": 3650 },
        { "type": "external_media", "label": "External Media", "clicks": 1150 }
      ],
      "platformDistribution": [
        { "platform": "linkedin",  "label": "LinkedIn",  "sharePct": 42 },
