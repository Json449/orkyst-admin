{
  "_README": "Sample API responses for the analytics module. Every value here matches the values seeded in analytics_seed.cypher and the numbers shown in the dashboard screenshots. Use these shapes as the contract between backend and frontend.",

  "GET /api/analytics/overview": {
    "description": "Top-of-page CTA Performance cards + Clicks-by-Content-Type bar chart + Platform Distribution donut. Range: last 30 days.",
    "screenshot": "Screenshot 1 (CTA Performance) + Screenshot 2 (Platform Distribution)",
